# ─── Database (Supabase) ───────────────────────────────────────────────────────
# Create a project at supabase.com, then grab these from Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Also set the DB connection string (Project Settings > Database > Connection string)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ─── Authentication (NextAuth) ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=your-32-char-hex-secret-here
# Local dev: http://localhost:3000  |  Production: https://your-domain.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ─── AI Summarization (Anthropic) ─────────────────────────────────────────────
# Required for executive summaries, lifecycle inference, deal extraction
# Get at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Free tier: 3,000 emails/month. Get at resend.com
# Note: verify your sender domain in Resend dashboard, or use onboarding@resend.dev for testing
RESEND_API_KEY=re_...
EMAIL_FROM=Economic Statecraft Monitor <alerts@yourdomain.com>
EMAIL_TO=Alan.g.Seabrooke.mil@us.navy.mil
# UTC time for daily email (24h format: HH:MM)
EMAIL_DAILY_TIME=06:00

# ─── Cron Security ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Vercel Cron passes this as Authorization: Bearer <secret>
CRON_SECRET=your-cron-secret-here

# ─── Optional Connectors ───────────────────────────────────────────────────────
# GDELT and World Bank need no keys (auto-enabled)
# Add keys below to enable additional connectors

# NewsAPI (newsapi.org) — free dev tier: 100 req/day
NEWSAPI_KEY=

# GNews (gnews.io) — free tier: 100 req/day
GNEWS_KEY=
